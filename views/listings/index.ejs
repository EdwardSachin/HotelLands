<% layout("/layouts/boilerplate") %>
<body>
    <h3 class="index-h3"> all listings</h3>
    <form method="GET" action="/listings/new" class="newbutton">
        <button type="submit">Create New Listing</button>
    </form>

    <div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1">
        
    <% for(let listing of alllistings){ %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
    <div class="card cols">
        <div class="card-img-overlay"></div>
        <img src="<%= listing.image %>" class="card-img-top" alt="listing_image" style="height: 25rem">
        <div class="card-body">
            <p class="card-text">
                <b><%= listing.title %> <br/></b>
                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night                <!--to make it to indian rupee -->
            </p>
        </div>
    </div>
    <% } %>
    </a>


    </div>




    
</body>



